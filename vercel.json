{
  
  "builds": [
    {
      "src": "index2.js",
      "use": "@vercel/node"
    },
      {
      "src": "build/**",
      "use": "@vercel/static"
       
    
    }


  ],

  
  "routes": [
    {
      "src": "/products",
      "dest": "index2.js"
    },
    {
      "src": "/products/(.*)",
      "dest": "index2.js"
    },
    {
      "src": "/",
      "dest": "build/index.html"
    },
     {
      "src": "/add",
      "dest": "build/index.html"
    },
    {
      "src": "/(.+)",
      "dest": "build/$1"
    }
  ]
}